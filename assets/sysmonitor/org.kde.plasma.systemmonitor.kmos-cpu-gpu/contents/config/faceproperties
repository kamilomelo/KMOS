[Config]
chartFace=org.kde.ksysguard.piechart
highPrioritySensorIds=["cpu/all/usage","gpu/all/usage"]
lowPrioritySensorIds=[]
totalSensors=["cpu/all/averageTemperature"]

[FaceConfig]
fromAngle=-180
rangeAuto=true
rangeFrom=0
rangeFromMultiplier=1
rangeFromUnit=-1
rangeTo=100
rangeToMultiplier=1
rangeToUnit=-1
showLegend=true
smoothEnds=true
toAngle=180

[SensorColors]
cpu/all/usage=117,117,117
gpu/all/usage=85,85,255
